{
  "name": "nestjs-api-boilerplate",
  "version": "1.0.0",
  "description": "A production-ready Nest.js API boilerplate with Better Auth, Prisma, Swagger, and Postman integration",
  "author": "",
  "private": true,
  "license": "SEE LICENSE IN LICENSE",
  "scripts": {
    "bootstrap": "pnpm install && npx lefthook install && docker-compose up -d postgres && npx --yes wait-on tcp:5433 -t 30000 && pnpm db:migrate && pnpm db:seed",
    "dev": "node ./scripts/db-reset.js && nest start --watch | pino-pretty",
    "build": "nest build",
    "start": "nest start",
    "start:debug": "nest start --debug --watch | pino-pretty",
    "start:prod": "node dist/main",
    "format": "pnpm exec biome format --write .",
    "lint": "pnpm exec biome check --write .",
    "typecheck": "tsc --noEmit && echo TypeScript check passed!",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:cov:watch": "jest --coverage --watch",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "test:unit": "jest --testPathIgnorePatterns=integration",
    "test:integration": "jest --testPathPattern=integration",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:reset": "prisma migrate reset --force",
    "db:seed": "ts-node prisma/seed.ts",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@nestjs/cache-manager": "^3.1.0",
    "@nestjs/common": "^11.1.6",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.6",
    "@nestjs/cqrs": "^11.0.3",
    "@nestjs/event-emitter": "^3.0.1",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/mapped-types": "*",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.6",
    "@nestjs/swagger": "^11.2.0",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/client": "^6.15.0",
    "@thallesp/nestjs-better-auth": "^2.4.0",
    "argon2": "^0.44.0",
    "better-auth": "^1.3.7",
    "cache-manager": "^7.2.8",
    "cache-manager-redis-yet": "^5.1.5",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "nestjs-i18n": "^10.4.5",
    "nestjs-pino": "^4.1.0",
    "openapi-to-postmanv2": "^4.20.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pino": "^9.9.0",
    "pino-http": "^10.3.0",
    "redis": "^5.10.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "zod": "latest"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.15",
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0",
    "@faker-js/faker": "^10.3.0",
    "@nestjs/cli": "^11.0.10",
    "@nestjs/schematics": "^11.0.7",
    "@nestjs/testing": "^11.1.6",
    "@types/express": "^5.0.3",
    "@types/jest": "^29.5.2",
    "@types/node": "^20.19.10",
    "@types/openapi-to-postmanv2": "^3.2.4",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^6.0.3",
    "jest": "^29.5.0",
    "jest-mock-extended": "^3.0.7",
    "lefthook": "^1.10.3",
    "pino-pretty": "^12.0.0",
    "prisma": "^6.15.0",
    "supertest": "^6.3.3",
    "ts-jest": "^29.4.1",
    "ts-loader": "^9.4.3",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.2",
    "wait-on": "^9.0.4"
  },
  "jest": {
    "collectCoverageFrom": [
      "**/*.ts",
      "!**/*.spec.ts",
      "!**/*.e2e-spec.ts",
      "!**/index.ts",
      "!**/main.ts",
      "!**/*.module.ts",
      "!**/test/**",
      "!**/fixtures/**",
      "!**/mocks/**",
      "!**/node_modules/**",
      "!**/dist/**",
      "!**/coverage/**",
      "!**/seeders/**",
      "!**/factories/**",
      "!**/scenarios/**",
      "!**/migrations/**",
      "!**/helpers/**",
      "!**/config/configurations.ts",
      "!**/auth/better-auth.config.ts",
      "!**/common/constants/**",
      "!**/common/decorators/throttle.decorator.ts",
      "!**/common/utils/**"
    ],
    "coverageDirectory": "./coverage",
    "coverageReporters": [
      "html",
      "text",
      "lcov",
      "json-summary"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 80,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    },
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "moduleNameMapper": {
      "@app/(.*)": "<rootDir>/src/$1",
      "^@thallesp/nestjs-better-auth$": "<rootDir>/test/mocks/better-auth.mock.ts"
    },
    "modulePaths": [
      "<rootDir>"
    ],
    "rootDir": "./",
    "roots": [
      "<rootDir>/src/"
    ],
    "testEnvironment": "node",
    "testRegex": ".*\\.spec\\.ts$",
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/dist/",
      "/coverage/"
    ],
    "testTimeout": 10000,
    "forceExit": true,
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    }
  },
  "prisma": {
    "schema": "./prisma"
  },
  "packageManager": "pnpm@10.6.4",
  "pnpm": {
    "overrides": {
      "lodash@>=4.0.0 <=4.17.22": ">=4.17.23",
      "js-yaml@>=4.0.0 <4.1.1": ">=4.1.1",
      "qs@>=6.7.0 <=6.14.1": ">=6.14.2"
    }
  }
}
